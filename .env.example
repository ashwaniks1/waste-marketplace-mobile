# Copy to .env and fill with your Supabase project (Settings → API).
# Do not commit .env. Never put the service_role key here.
EXPO_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
EXPO_PUBLIC_SUPABASE_ANON_KEY="sb_publishable_YOUR_ANON_KEY"

# Next.js deployment origin (profile provisioning). Required for signup/profile self-heal.
EXPO_PUBLIC_APP_API_URL="https://YOUR_NEXT_APP.example.com"

# Optional: mobile error reporting (use a dev build for full native support)
# EXPO_PUBLIC_SENTRY_DSN="https://...@.ingest.sentry.io/..."

# Optional (used for push token registration endpoints later)
EXPO_PUBLIC_ENV="development"

